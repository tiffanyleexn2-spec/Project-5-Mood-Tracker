# Firebase Configuration for Mood Tracker
# Copy this file to .env and add your Firebase credentials

# Get these values from your Firebase project settings:
# https://console.firebase.google.com/ → Project Settings → General → Your apps → Firebase SDK snippet → Config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789

# Setup Instructions:
# 1. Create a Firebase project at https://console.firebase.google.com/
# 2. Enable Authentication (Email/Password)
# 3. Create a Firestore database
# 4. Copy this file: cp .env.example .env
# 5. Replace the values above with your actual Firebase config
# 6. Run: npm run dev

# Security Note:
# - Never commit .env file to git
# - The .env file is already in .gitignore
# - Each student needs their own Firebase project
